---
const { tags } = Astro.props;
---

{
  tags?.length && (
    <ul class="flex items-center gap-x-1 list-none pl-0 m-0!">
      {tags.map((tag) => (
        <li class="inline-flex m-0! p-0!">
          <span
            class={`rounded-lg px-1.5 py-0.5 text-xs text-background dark:text-foreground bg-${tag.color}`}
          >
            {tag.name}
          </span>
        </li>
      ))}
    </ul>
  )
}
