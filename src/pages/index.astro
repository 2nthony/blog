---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { getPostList } from "../lib/notion/index";
import { siteConfig } from "../../site.config.mjs";

const posts = await getPostList();
---

<BaseLayout>
  <Header slot="header" />

  <div>
    <p>{siteConfig.description}</p>
  </div>

  <hr />

  <div>
    <ul class="pl-0">
      {
        posts.map((post) => (
          <li class="my-6 list-none pl-0">
            <h3 class="text-2xl font-bold mb-2">
              <a
                class="no-underline hover:underline cursor-pointer"
                href={post.attributes.slug}
              >
                {post.attributes.title}
              </a>
            </h3>
            <p class="text-foreground/70 mb-2">{post.attributes.description}</p>
            <time class="text-foreground/70 text-sm">
              {post.attributes.date}
            </time>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
