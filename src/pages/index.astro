---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { siteConfig } from "../../site.config.mjs";
import BaseHead from "../components/BaseHead.astro";
import { getLiveCollection } from "astro:content";

const { entries } = await getLiveCollection("posts");
---

<BaseLayout>
  <Fragment slot="head">
    <head>
      <BaseHead title={siteConfig.title} />
    </head>
  </Fragment>

  <Header />

  <div>
    <p>{siteConfig.description}</p>
  </div>

  <hr />

  <div>
    <ul class="pl-0">
      {
        entries.map((entry) => (
          <li class="my-6 list-none pl-0">
            <h3 class="text-2xl font-bold mb-2">
              <a
                class="no-underline hover:underline cursor-pointer"
                href={`/posts/${entry.data.attributes.slug}`}
              >
                {entry.data.attributes.title}
              </a>
            </h3>
            <p class="text-foreground/70 mb-2">
              {entry.data.attributes.description}
            </p>
            <time class="text-foreground/70 text-sm">
              {entry.data.attributes.date}
            </time>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
